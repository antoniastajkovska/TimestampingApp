# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
# All paths are relative to the backend/ directory (where you run the app from).

# ── TLS keystore / truststore passwords (set by generate-certs.sh) ──────────
SSL_KEYSTORE_PASSWORD=T1m3stamp#KS
SSL_TRUSTSTORE_PASSWORD=T1m3stamp#TS

# ── TLS keystore / truststore paths ─────────────────────────────────────────
SSL_KEYSTORE_PATH=../certs/keystore.p12
# Uncomment to enable mTLS:
# SSL_CLIENT_AUTH=need
# SSL_TRUSTSTORE_PATH=../certs/truststore.p12

# ── TSA signing keystore (used by CryptoService for PS256 JWS signing) ───────
TSA_KEYSTORE_PATH=../certs/tsa-keystore.p12
TSA_KEYSTORE_PASSWORD=T1m3stamp#TSA
TSA_CERT_PATH=../certs/tsa.crt

# ── Client cert password (for browser import of client.p12) ─────────────────
CLIENT_CERT_PASSWORD=T1m3stamp#Client

# ── React dev server TLS (uses your PKI cert instead of webpack's self-signed) ──
SSL_CRT_FILE=../certs/chain.crt
SSL_KEY_FILE=../certs/tls.key

# ── Database ─────────────────────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=postgres

# ── Email (Gmail App Password) ───────────────────────────────────────────────
MAIL_USER=timestampingapp.dev@gmail.com
MAIL_PASS=cjbfpciwvpnbmsqm
